# FAL.ai API Key - https://fal.ai/dashboard/keys 에서 발급 (AI Video용)
FAL_KEY=your_fal_api_key_here

# OpenAI API Key - https://platform.openai.com/api-keys 에서 발급 (AI Image용)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: 생성 영상 최대 길이 (초)
MAX_DURATION=10

# Optional: 외부 API 인증 토큰 (곰픽 연동용, 미설정시 인증 없이 사용 가능)
API_TOKEN=your_api_token_here
